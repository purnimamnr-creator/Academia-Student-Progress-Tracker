rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Security Helpers
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is the owner of the document (by URL parameter)
    function isUserSelf(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if the user is an admin (defaulted to the creator's email)
    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.get('email', '') == "purnima.mnr@gmail.com" && request.auth.token.get('email_verified', false) == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin')
      );
    }

    // Check if the user owns the data via the 'uid' field in the document
    function isOwner() {
      return isAuthenticated() && (
        (resource == null && request.resource.data.uid == request.auth.uid) || 
        (resource != null && resource.data.uid == request.auth.uid) ||
        isAdmin()
      );
    }

    // Validate User Profile schema
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'displayName', 'role']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.role in ['teacher', 'student'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User profiles: Each user can only read and write their own data
    // or teachers can manage students they are assigned to
    match /users/{userId} {
      allow read: if isUserSelf(userId) || 
                     (isAuthenticated() && (
                       (resource != null && (resource.data.teacherUid == request.auth.uid || resource.data.uid == request.auth.uid)) ||
                       isAdmin()
                     ));
      
      allow create: if (isAuthenticated() && (
                        request.auth.uid == userId || 
                        request.resource.data.teacherUid == request.auth.uid
                      ) && isValidUserProfile(request.resource.data)) || isAdmin();
      
      allow update: if (isAuthenticated() && (
                        userId == request.auth.uid || 
                        resource.data.teacherUid == request.auth.uid
                      ) && isValidUserProfile(request.resource.data)) || isAdmin();

      allow delete: if isUserSelf(userId) || 
                      (resource != null && resource.data.teacherUid == request.auth.uid) || 
                      isAdmin();
    }

    // Scores: Only the owner can access their own scores
    match /scores/{id} {
      allow read, write: if isOwner();
    }

    // Merits: Only the owner can access their own merits
    match /merits/{id} {
      allow read, write: if isOwner();
    }

    // Goals: Only the owner can access their own goals
    match /goals/{id} {
      allow read, write: if isOwner();
    }

    // Sessions: Only the owner can access their own sessions
    match /sessions/{id} {
      allow read, write: if isOwner();
    }
  }
}
