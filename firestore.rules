rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Security Helpers
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is the owner of the document (by URL parameter)
    function isUserSelf(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if the user owns the data via the 'uid' field in the document
    function isOwner() {
      return isAuthenticated() && (
        (resource == null && request.resource.data.uid == request.auth.uid) || 
        (resource != null && resource.data.uid == request.auth.uid)
      );
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User profiles: Each user can only read and write their own data
    // or teachers can manage students they are assigned to
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        userId == request.auth.uid || 
        (resource != null && resource.data.get('teacherUid', '') == request.auth.uid)
      );
      
      allow create: if isAuthenticated() && (
        request.auth.uid == userId || 
        request.resource.data.get('teacherUid', '') == request.auth.uid
      );
      
      allow update, delete: if isAuthenticated() && (
        userId == request.auth.uid || 
        (resource != null && resource.data.get('teacherUid', '') == request.auth.uid)
      );
    }

    // Scores: Only the owner can access their own scores
    match /scores/{id} {
      allow read, write: if isOwner();
    }

    // Merits: Only the owner can access their own merits
    match /merits/{id} {
      allow read, write: if isOwner();
    }

    // Goals: Only the owner can access their own goals
    match /goals/{id} {
      allow read, write: if isOwner();
    }

    // Sessions: Only the owner can access their own sessions
    match /sessions/{id} {
      allow read, write: if isOwner();
    }
  }
}
